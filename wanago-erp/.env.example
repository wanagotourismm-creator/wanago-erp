# Copy to .env.local and fill in. Never commit real values.

# Firebase (client SDK config — safe to expose, scoped by Firestore rules)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-only, service account JSON as a single-line string)
FIREBASE_SERVICE_ACCOUNT_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Wanago ERP
NEXT_PUBLIC_APP_ENV=development

# Supabase (reporting mirror only, not primary datastore)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI
GEMINI_API_KEY=
GROQ_API_KEY=

# Vercel Cron auth (see src/app/api/cron/*)
CRON_SECRET=

# GlitchTip (self-hosted, Sentry-protocol) error tracking — blank disables it
NEXT_PUBLIC_ERROR_TRACKING_DSN=
ERROR_TRACKING_DSN=
ERROR_TRACKING_ORG=
ERROR_TRACKING_PROJECT=
ERROR_TRACKING_AUTH_TOKEN=
SENTRY_URL=
