rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.systemRole;
    }

    function isSuperAdmin() {
      return getUserRole() == 'super_admin';
    }

    function isAdmin() {
      return getUserRole() in ['super_admin', 'admin'];
    }

    function isSameOffice(officeId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.officeId == officeId;
    }

    function getUserDepartment() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department;
    }

    // A department-scoped Team Space channel (department != null) is only
    // readable/postable by members of that department, or an admin.
    // `department == null` means "everyone in the office."
    function canAccessChannel(channelId) {
      let ch = get(/databases/$(database)/documents/teamspaceChannels/$(channelId)).data;
      return ch.department == null || ch.department == getUserDepartment() || isAdmin();
    }

    // Everyone who can read a channel can read its announcements, but only
    // Admin/Super Admin/HR may post into a `type == 'announcement'` channel
    // (matches TeamSpacePanel's canPostAnnouncement) — previously this was
    // only enforced by hiding the composer in the UI.
    function canPostToChannel(channelId) {
      let ch = get(/databases/$(database)/documents/teamspaceChannels/$(channelId)).data;
      return canAccessChannel(channelId) && (ch.type != 'announcement' || getUserRole() in ['super_admin', 'admin', 'hr']);
    }

    function hasRequiredFields() {
      return request.resource.data.keys().hasAll(['createdAt', 'updatedAt', 'createdBy', 'status']);
    }

    // ── Assignment-based visibility (leads/customers/bookings) ────
    // assignedTo stores an Employee.id, not a uid, so resolving "which
    // employee is this signed-in user" needs the employeeId denormalized
    // onto users/{uid} at account-link time (see employee.service.ts's
    // syncEmployeeIdOnUser). Missing/unsynced accounts just get null here,
    // which safely falls through to "can't see assigned-to-someone-else
    // records" rather than throwing.
    function getUserEmployeeId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('employeeId', null);
    }

    // Mirrors PERMISSION_MAP in src/lib/rbac.ts: an admin-set override for
    // this role (settings/rolePermissions) wins if present; otherwise fall
    // back to the static defaults below. KEEP THESE IN SYNC WITH
    // PERMISSION_MAP — duplicated here because rules can't import the TS
    // source of truth. Today's defaults: Operations and Sales Head see
    // every lead/customer/booking; Finance additionally sees every
    // booking (needed to approve bookings it isn't assigned to) but has
    // no leads/customers access at all. Super Admin/Admin bypass via
    // isAdmin() at each call site; everyone else only sees unassigned
    // records plus their own.
    function defaultViewAllRoles(permission) {
      return permission == 'bookings:view_all'
        ? ['operations', 'sales_head', 'finance']
        : ['operations', 'sales_head'];
    }
    function roleCanViewAll(permission) {
      let role = getUserRole();
      // get() on a doc that doesn't exist yet (no admin has saved an
      // override) throws when you touch .data, so guard with exists()
      // first — same reason fetchRolePermissions() falls back to
      // PERMISSION_MAP client-side when the doc is missing.
      let override = exists(/databases/$(database)/documents/settings/rolePermissions)
        ? get(/databases/$(database)/documents/settings/rolePermissions).data.get('roles', {}).get(role, null)
        : null;
      return override != null ? (permission in override) : (role in defaultViewAllRoles(permission));
    }

    // The shared read condition for leads/customers/bookings: Admin/Super
    // Admin and any role with the view_all permission see everything;
    // everyone else only sees a record that's unassigned (anyone can still
    // claim it) or assigned specifically to them.
    function canViewAssigned(permission) {
      return isAdmin() || roleCanViewAll(permission) ||
        resource.data.get('assignedTo', null) == null ||
        resource.data.get('assignedTo', null) == getUserEmployeeId();
    }

    // whatsappMessages don't carry their own assignedTo — visibility
    // follows whichever conversation they belong to, same "unassigned or
    // mine" rule as canViewAssigned above. No dedicated 'whatsapp:view_all'
    // permission exists in PERMISSION_MAP, so roleCanViewAll() falls back
    // to defaultViewAllRoles' generic branch (operations, sales_head) —
    // same default every other unassigned-permission collection gets.
    function canViewWhatsAppConversation(conversationId) {
      let convo = get(/databases/$(database)/documents/whatsappConversations/$(conversationId)).data;
      return isAdmin() || roleCanViewAll('whatsapp:view_all') ||
        convo.get('assignedTo', null) == null ||
        convo.get('assignedTo', null) == getUserEmployeeId();
    }

    // ── Catch-all exclusion lists ─────────────────────────────
    // IMPORTANT: Firestore evaluates every `match` block whose path pattern
    // matches a request and grants access if ANY of them allow it (rules are
    // OR'd, not "most-specific wins" — confirmed live against this project).
    // That means the generic catch-all at the bottom of this file (its own
    // comment explains the mechanism in more detail) silently RE-GRANTS
    // broad access to every collection below unless explicitly excluded here
    // — a dedicated stricter rule above does nothing on its own. Any
    // collection with a dedicated rule stricter than plain
    // isAuthenticated()+hasRequiredFields() for a given verb MUST be listed
    // in that verb's function below, or its restriction is a no-op.
    function isReadRestricted(collectionName) {
      return collectionName in [
        'activities', 'systemUsage', 'teamPulseResponses', 'referralPartners',
        'aiUsageLogs', 'aiActionLogs', 'aiPredictions',
        'hrmsPayroll', 'hrmsSuspiciousAttendance',
        'performanceReviews', 'performanceGoals', 'candidates', 'jobOpenings',
        // Each has its own dedicated, stricter read rule above
        // (canViewAssigned) — without this exclusion the catch-all's plain
        // isAuthenticated() grant silently re-opens them to everyone.
        'leads', 'customers', 'bookings',
        // Same reasoning — canViewAssigned/canViewWhatsAppConversation.
        'whatsappConversations', 'whatsappMessages'
      ];
    }

    function isCreateRestricted(collectionName) {
      return collectionName in [
        'users', 'offices', 'quotations', 'invoices', 'payments', 'expenses',
        'packages', 'suppliers', 'itineraries', 'itineraryBrochures', 'campaigns',
        'hrmsEmployees', 'hrmsCheckIns', 'trainingPrograms', 'trainingEnrollments', 'hrmsPayroll',
        'onboardingTasks', 'onboardingTrainingModules', 'onboardingTrainingSteps',
        'onboardingTrainingProgress', 'trainingCertificates', 'trainingPracticeSubmissions',
        'helpArticles', 'hrPolicyDocuments',
        'performanceReviews', 'performanceGoals', 'candidates', 'jobOpenings',
        'companyGoals', 'objectives', 'goalCheckIns',
        'referralPartners', 'referralPosters', 'referralClicks',
        'assets', 'settings', 'bookingRequests', 'quickInquiries', 'holidays',
        'systemUsage', 'aiUsageLogs', 'aiActionLogs', 'aiPredictions',
        'whatsappTemplates', 'teamPulseResponses', 'digests',
        // All real writes happen server-side via the Admin SDK (the
        // review-requests cron and the public /review/{token} route) —
        // no legitimate client create path exists, same reasoning as
        // whatsappTemplates.
        'npsResponses',
        // Admin-configured ledger-mapping table (Tally export) — same
        // reasoning as whatsappTemplates, no non-admin write path needed.
        'tallyMappings',
        // Marketing-configured journey/segment definitions — same
        // reasoning, no non-admin write path needed.
        'journeys', 'segments'
      ];
    }

    function isUpdateRestricted(collectionName) {
      return collectionName in [
        'users', 'offices', 'leads', 'customers', 'bookings', 'whatsappConversations', 'quotations', 'invoices',
        'payments', 'expenses', 'packages', 'suppliers', 'itineraries',
        'itineraryBrochures', 'campaigns', 'hrmsEmployees', 'hrmsCheckIns',
        'hrmsLeaves', 'hrmsRegularizations', 'tickets',
        'trainingPrograms', 'trainingEnrollments', 'hrmsPayroll', 'hrmsSuspiciousAttendance',
        'onboardingTasks', 'onboardingTrainingModules', 'onboardingTrainingSteps',
        'onboardingTrainingProgress', 'trainingCertificates', 'trainingPracticeSubmissions',
        'notifications', 'settings', 'referralBonuses', 'referralPartners', 'referralPosters',
        'referralClicks', 'assets', 'assetRequests', 'holidays',
        'performanceReviews', 'performanceGoals', 'candidates', 'jobOpenings',
        'companyGoals', 'objectives', 'goalCheckIns', 'helpArticles', 'hrPolicyDocuments',
        'systemUsage', 'aiUsageLogs', 'aiActionLogs', 'aiPredictions',
        'whatsappTemplates', 'teamPulseResponses', 'digests', 'activities', 'trash',
        'npsResponses', 'tallyMappings', 'journeys', 'segments'
      ];
    }

    // Shared by hrmsLeaves and assetRequests: a request may be updated by
    // HR/Admin, by the employee it belongs to (e.g. cancelling their own
    // request), or by that employee's direct reporting manager (the ESS
    // "approve/reject" inbox flow).
    function employeeById(employeeId) {
      return get(/databases/$(database)/documents/hrmsEmployees/$(employeeId)).data;
    }
    function isOwnerOrManagerOfEmployee(employeeId) {
      let emp = employeeById(employeeId);
      return request.auth.uid == emp.userId ||
             (emp.reportingManagerId != null &&
              employeeById(emp.reportingManagerId).userId == request.auth.uid);
    }
    // Attendance location-approval requests specifically route to BOTH the
    // reporting manager and the functional manager (see notifyManagerOfLocationRequest
    // in useEss.ts) — functionalManagerId otherwise never drives approval
    // routing (see its own comment in hrms/shared/types.ts), so this is
    // deliberately its own function rather than widening
    // isOwnerOrManagerOfEmployee itself, which stays reporting-manager-only
    // for leaves/regularizations/assetRequests.
    function isOwnerOrEitherManagerOfEmployee(employeeId) {
      let emp = employeeById(employeeId);
      return isOwnerOrManagerOfEmployee(employeeId) ||
             (emp.functionalManagerId != null &&
              employeeById(emp.functionalManagerId).userId == request.auth.uid);
    }
    // The manager-only half of isOwnerOrEitherManagerOfEmployee, with the
    // owner branch stripped out — hrmsCheckIns' create rule uses this
    // instead of the owner-inclusive version so an employee can never
    // create their own attendance record by writing this collection
    // directly (see attendanceOwnerWriteIsSafe below for why that matters).
    // A manager still needs full create access here for regularization
    // approval's backfill write (approveRegularization in
    // regularization.service.ts).
    function isEitherManagerOfEmployee(employeeId) {
      let emp = employeeById(employeeId);
      return (emp.reportingManagerId != null &&
              employeeById(emp.reportingManagerId).userId == request.auth.uid) ||
             (emp.functionalManagerId != null &&
              employeeById(emp.functionalManagerId).userId == request.auth.uid);
    }
    function isEmployeeOwner(employeeId) {
      return employeeById(employeeId).userId == request.auth.uid;
    }
    // isOwnerOrManagerOfEmployee's "owner" half exists so an employee can
    // cancel/edit their own request — but without this, it also let them
    // approve/reject their OWN request by writing the decision fields
    // directly (the manager half of that same OR is meant to be the only
    // path that can). Each *OwnerWriteIsSafe() below is ANDed onto the
    // relevant collection's update rule: a no-op for the manager/HR/Admin
    // path, but blocks the owner from touching the approval trail (and,
    // for leaves, from setting status to anything but 'cancelled' — its one
    // legitimate owner-triggered transition, see cancelLeaveRequest).
    function leaveOwnerWriteIsSafe(employeeId) {
      return !isEmployeeOwner(employeeId) || (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(
          ['approvedBy', 'approvedAt', 'rejectedBy', 'rejectedAt']
        ) &&
        (request.resource.data.status == resource.data.status || request.resource.data.status == 'cancelled')
      );
    }
    // Regularizations/asset requests have no owner-triggered update at all
    // today (no cancel/withdraw flow exists client-side) — so unlike
    // leaves, the owner is blocked from touching the status field too.
    function regularizationOwnerWriteIsSafe(employeeId) {
      return !isEmployeeOwner(employeeId) || !request.resource.data.diff(resource.data).affectedKeys().hasAny(
        ['regularizationStatus', 'approvedBy', 'approvedAt', 'rejectedBy', 'rejectedAt']
      );
    }
    function assetRequestOwnerWriteIsSafe(employeeId) {
      return !isEmployeeOwner(employeeId) || !request.resource.data.diff(resource.data).affectedKeys().hasAny(
        ['requestStatus', 'approvedBy', 'approvedAt', 'rejectedBy']
      );
    }
    // Deliberately an allowlist, not a blocklist like its three siblings
    // above. Those only need to keep an owner off a short, stable list of
    // approval-trail fields; everything else about a leave/regularization/
    // asset request is fair game for its own owner to edit. Attendance is
    // the opposite shape — the ONLY legitimate self-write any client flow
    // ever makes is starting/ending a break (startBreak/endBreak in
    // useEss.ts/useQuickClock.ts). clockIn/clockOut, the geofence result,
    // the selfie URL, and locationApprovalStatus are meant to be written
    // exclusively by the hardened /api/hrms/attendance/clock route (Admin
    // SDK, bypasses this rule) or by a manager/HR — so this fails closed:
    // a new field added to AttendanceRecord later is owner-blocked by
    // default until someone deliberately adds it here, instead of silently
    // becoming another way to self-fake attendance.
    function attendanceOwnerWriteIsSafe(employeeId) {
      return !isEmployeeOwner(employeeId) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['breakStartTime', 'breakMinutes', 'updatedAt']);
    }

    // Bookings: only Finance/Ops/Admin may touch the approval trail fields.
    // Rejection-trail fields are the exception — `updateBooking`'s resubmit
    // flow (booking.service.ts) clears them to null as a side effect of any
    // authenticated user editing their own rejected booking, so clearing is
    // allowed for everyone; only *setting* them (the actual reject action)
    // requires the approval role.
    function bookingTouchesApprovalFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'financeApprovedBy', 'financeApprovedAt', 'paymentVerification',
        'opsApprovedBy', 'opsApprovedAt', 'profitAmount'
      ]);
    }
    function bookingSetsRejectionFields() {
      let d = request.resource.data;
      return (('financeRejectedBy' in d) && d.financeRejectedBy != null) ||
             (('opsRejectedBy' in d) && d.opsRejectedBy != null);
    }
    // `status` itself must also be approval-gated — otherwise anyone could
    // write e.g. {status:'confirmed'} directly and skip Finance/Ops review
    // entirely. The one status change allowed without the approval role is
    // updateBooking's resubmit flow moving a rejected booking back to its
    // matching pending queue (paired with clearing rejection fields above).
    function bookingStatusChangeIsSafe() {
      return request.resource.data.status == resource.data.status ||
             (resource.data.status == 'finance_rejected' && request.resource.data.status == 'pending_finance') ||
             (resource.data.status == 'ops_rejected' && request.resource.data.status == 'ops_pending');
    }
    // Reassigning the sales agent on a booking/customer is restricted in the
    // UI (canReassignSalesAgent) to admin/super_admin/sales_head — enforce
    // the same thing here so it can't be bypassed with a direct write.
    function touchesAssignmentFields(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }
    function canReassign() {
      return getUserRole() in ['super_admin', 'admin', 'sales_head'];
    }

    // Quotations: only Finance/Admin may touch the approval trail, except
    // the one resubmit transition (rejected -> pending, no other approval
    // field touched) which `updateQuotation` performs for any authenticated
    // user editing their own rejected quotation.
    function quotationTouchesApprovalFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'financeApprovalStatus', 'financeApprovedBy', 'financeApprovedAt',
        'financeRejectedBy', 'financeRejectedAt', 'financeRejectionReason'
      ]);
    }
    function isQuotationResubmit() {
      return resource.data.financeApprovalStatus == 'rejected' &&
             request.resource.data.financeApprovalStatus == 'pending' &&
             !request.resource.data.diff(resource.data).affectedKeys().hasAny([
               'financeApprovedBy', 'financeApprovedAt',
               'financeRejectedBy', 'financeRejectedAt', 'financeRejectionReason'
             ]);
    }

    // Tickets: reported-by/assigned-to are hrmsEmployee ids, same shape as
    // hrmsLeaves' employeeId — a ticket may be updated by whoever reported
    // it, whoever it's currently assigned to, someone claiming an
    // unassigned ticket for themselves (assignToMe), or HR/Admin.
    function isTicketReporter(t) {
      return employeeById(t.reportedById).userId == request.auth.uid;
    }
    function isTicketAssignee(t) {
      return t.assignedToId != null && employeeById(t.assignedToId).userId == request.auth.uid;
    }
    function isClaimingTicket(t) {
      return t.assignedToId == null &&
             request.resource.data.assignedToId != null &&
             employeeById(request.resource.data.assignedToId).userId == request.auth.uid;
    }

    // ── Users ────────────────────────────────────────────────
    // A user may update their own profile fields (displayName, phone,
    // theme, etc.), but not the privilege/access fields — those require
    // Admin, otherwise any signed-in user could self-escalate by writing
    // {systemRole:'super_admin'} straight to their own document.
    match /users/{userId} {
      allow read: if isAuthenticated();
      // HR needs to create a login account as part of adding a new employee
      // (EmployeeForm's "Create a My HR login" step) — but must not be able
      // to grant admin-level access through that side door, so the systemRole
      // being written is capped to non-admin roles for that path.
      allow create: if isAdmin() || (
        getUserRole() == 'hr' &&
        !(request.resource.data.systemRole in ['super_admin', 'admin'])
      );
      allow update: if isAdmin() || (
        isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(
          ['systemRole', 'teamRole', 'officeId', 'isActive', 'customPageAccess']
        )
      );
      allow delete: if isSuperAdmin();
    }

    // ── Offices ──────────────────────────────────────────────
    // The Roles & Permissions editor treats `admin:offices` as grantable to
    // the Admin role (matching admin:users/admin:settings) — the rule was
    // hardcoded to Super Admin only, so a plain Admin saw a fully-functional
    // Offices tab where every write silently failed.
    match /offices/{officeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Leads ────────────────────────────────────────────────
    // Reassignment must be gated the same way customers/bookings already
    // are — previously any authenticated user could update a lead's
    // assignedTo/agentName directly (LeadForm.tsx only *hides* the field
    // once a lead is claimed; it never actually blocked the underlying
    // write), so any sales agent could silently steal a colleague's lead
    // via a direct write bypassing the form.
    match /leads/{leadId} {
      allow read: if isAuthenticated() && canViewAssigned('leads:view_all');
      allow create: if isAuthenticated() && hasRequiredFields();
      allow update: if isAuthenticated() && (
        !touchesAssignmentFields(['assignedTo', 'agentName']) || canReassign()
      );
      allow delete: if isAdmin();
    }

    // ── Customers ────────────────────────────────────────────
    match /customers/{customerId} {
      allow read: if isAuthenticated() && canViewAssigned('customers:view_all');
      allow create: if isAuthenticated() && hasRequiredFields();
      allow update: if isAuthenticated() && (
        !touchesAssignmentFields(['assignedTo']) || canReassign()
      );
      allow delete: if isAdmin();
    }

    // ── Bookings ─────────────────────────────────────────────
    // Normal field edits (destination, dates, notes, etc.) stay open to any
    // authenticated user, matching the existing edit flow — but the
    // Finance/Operations approval trail fields may only be touched by a
    // request that also has an approval-capable role, so the approve/
    // reject actions can't be replayed by an arbitrary authenticated user
    // (they were previously gated only by hiding the button in the UI).
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && canViewAssigned('bookings:view_all');
      allow create: if isAuthenticated() && hasRequiredFields();
      allow update: if isAuthenticated() && (
        (
          !bookingTouchesApprovalFields() && !bookingSetsRejectionFields() &&
          bookingStatusChangeIsSafe() &&
          (!touchesAssignmentFields(['assignedTo', 'agentName']) || canReassign())
        ) ||
        getUserRole() in ['super_admin', 'admin', 'finance', 'operations']
      );
      allow delete: if isAdmin();
    }

    // ── Quotations ───────────────────────────────────────────
    match /quotations/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                       getUserRole() in ['super_admin','admin','sales'];
      allow update: if isAuthenticated() &&
                       getUserRole() in ['super_admin','admin','sales','finance'] && (
                         !quotationTouchesApprovalFields() ||
                         isQuotationResubmit() ||
                         getUserRole() in ['super_admin','admin','finance']
                       );
      allow delete: if isAdmin();
    }

    // ── Finance (invoices, payments, expenses) ───────────────
    match /invoices/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      getUserRole() in ['super_admin','admin','finance'];
    }

    match /payments/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      getUserRole() in ['super_admin','admin','finance'];
    }

    match /expenses/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      getUserRole() in ['super_admin','admin','finance'];
    }

    // ── Operations (packages, suppliers, itineraries) ────────
    match /packages/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      getUserRole() in ['super_admin','admin','operations','sales'];
    }

    match /suppliers/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      getUserRole() in ['super_admin','admin','operations'];
    }

    match /itineraries/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      getUserRole() in ['super_admin','admin','operations','sales'];
    }

    match /itineraryBrochures/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      getUserRole() in ['super_admin','admin','operations','sales'];
    }

    // ── Marketing ─────────────────────────────────────────────
    match /campaigns/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      getUserRole() in ['super_admin','admin','marketing'];
    }

    // ── HRMS ─────────────────────────────────────────────────
    match /hrmsEmployees/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      getUserRole() in ['super_admin','admin','hr'];
    }

    // Previously any authenticated user could approve or delete anyone
    // else's leave request since this only checked login — now it must be
    // the employee themself, their direct manager, or HR/Admin. Delete
    // includes HR (matches LeaveTable's delete button, which HR can see).
    match /hrmsLeaves/{id} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields();
      allow update: if isAuthenticated() && (
        isOwnerOrManagerOfEmployee(resource.data.employeeId) ||
        getUserRole() in ['super_admin', 'admin', 'hr']
      ) && leaveOwnerWriteIsSafe(resource.data.employeeId);
      allow delete: if getUserRole() in ['super_admin', 'admin', 'hr'];
    }

    // Same owner/manager/HR model as hrmsLeaves — previously had no
    // dedicated rule at all (fell through to the permissive catch-all),
    // so any authenticated user could approve/reject/delete any other
    // employee's attendance correction request.
    match /hrmsRegularizations/{id} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields();
      allow update: if isAuthenticated() && (
        isOwnerOrManagerOfEmployee(resource.data.employeeId) ||
        getUserRole() in ['super_admin', 'admin', 'hr']
      ) && regularizationOwnerWriteIsSafe(resource.data.employeeId);
      allow delete: if getUserRole() in ['super_admin', 'admin', 'hr'];
    }

    // IT support tickets — previously had no dedicated rule (fell through
    // to the permissive catch-all), so any authenticated user could delete,
    // reassign, or resolve any other employee's ticket. Reporter can edit
    // their own; the current assignee can update it (resolve); anyone can
    // claim an unassigned ticket for themselves; Admin/Super Admin manage all.
    match /tickets/{id} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields();
      allow update: if isAuthenticated() && (
        isTicketReporter(resource.data) || isTicketAssignee(resource.data) ||
        isClaimingTicket(resource.data) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Training catalog (separate from onboarding-training walkthroughs) —
    // previously had no dedicated rule, so program/enrollment CRUD was only
    // gated by hiding the buttons behind hrms:manage in the UI.
    match /trainingPrograms/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
    }

    match /trainingEnrollments/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
    }

    // Employee's own payslip read added for the ESS "My Payslips" section
    // (MyPayslipsList/fetchPayrollByEmployee) — previously only
    // super_admin/admin/hr/finance could read at all, so that fetch
    // permission-denied for every other role and (since useEss.ts loads it
    // in the same Promise.all as attendance/leaves/etc) failed the entire
    // ESS dashboard load for any non-HR/finance/admin employee.
    match /hrmsPayroll/{id} {
      allow read: if isAuthenticated() && (
        getUserRole() in ['super_admin','admin','hr','finance'] ||
        isEmployeeOwner(resource.data.employeeId)
      );
      allow write: if isAuthenticated() &&
                      getUserRole() in ['super_admin','admin','hr'];
    }

    // Clock-in/out itself goes through /api/hrms/attendance/clock (Admin
    // SDK, bypasses these rules entirely) — that route re-derives the
    // geofence result and runs the fraud heuristics server-side, which a
    // direct client-SDK write to this collection would skip entirely.
    // HR's manual "Add Attendance" form, regularization-approval backfills,
    // and location-approval decisions still write here directly, so those
    // paths (HR/Admin, or the employee's manager) keep create/update
    // access — but the employee themselves is deliberately NOT part of the
    // create rule, and is confined to only the break fields on update (see
    // isEitherManagerOfEmployee and attendanceOwnerWriteIsSafe above).
    // Previously any authenticated user could read/write ANY employee's
    // attendance record directly, which is exactly the class of bug the
    // server route was built to close — a direct Firestore write bypassed
    // it completely; this collection's rules are what actually enforces
    // that the bypass stays closed.
    match /hrmsCheckIns/{id} {
      allow read: if isAuthenticated();
      // Deliberately manager-or-HR only, NOT owner-inclusive — an
      // employee's own clock-in must go through /api/hrms/attendance/clock
      // (Admin SDK, bypasses this rule), which re-derives the geofence
      // result and runs the fraud heuristics server-side. Letting the
      // owner create here directly would let them write
      // { withinGeofence: true, clockInSelfieUrl: null, ... } straight
      // into Firestore and skip all of that. Managers still need create
      // access for regularization approval's backfill write
      // (approveRegularization in regularization.service.ts).
      allow create: if isAuthenticated() && (
        isEitherManagerOfEmployee(request.resource.data.employeeId) ||
        getUserRole() in ['super_admin', 'admin', 'hr']
      );
      // Either manager may decide a pending location-approval request
      // (decideLocationApproval in attendance.service.ts) — see
      // isOwnerOrEitherManagerOfEmployee's own comment for why this one
      // collection includes the functional manager and the others don't.
      // The owner branch stays (break start/end is a legitimate direct
      // self-write) but attendanceOwnerWriteIsSafe below confines it to
      // only the break fields — same reasoning as the create rule above.
      allow update: if isAuthenticated() && (
        (isOwnerOrEitherManagerOfEmployee(resource.data.employeeId) &&
         attendanceOwnerWriteIsSafe(resource.data.employeeId)) ||
        getUserRole() in ['super_admin', 'admin', 'hr']
      );
      allow delete: if getUserRole() in ['super_admin', 'admin', 'hr'];
    }

    // Suspicious-location check-in/out attempts (heuristic fraud flags).
    // Create is open to any authenticated user because the flagged
    // employee's own client is what writes the log entry as a side effect
    // of their own blocked attempt — but only HR/Admin can ever read,
    // update (mark reviewed), or delete these, so an employee can't see
    // what tripped the heuristic or erase their own flagged history.
    match /hrmsSuspiciousAttendance/{id} {
      allow read: if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
      allow create: if isAuthenticated() && hasRequiredFields();
      allow update, delete: if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
    }

    match /onboardingTasks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                      getUserRole() in ['super_admin','admin','hr'];
    }

    // ── Team Space ───────────────────────────────────────────
    // Channel docs themselves are always listable (so the sidebar can show
    // channel names) — the department gate lives on who can read/post
    // *messages* in a department-scoped channel, enforced below.
    match /teamspaceChannels/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /teamspaceConversations/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /teamspaceMessages/{id} {
      allow read: if isAuthenticated() &&
                     (resource.data.convType != 'channel' || canAccessChannel(resource.data.convId));
      allow create: if isAuthenticated() &&
                       (request.resource.data.convType != 'channel' || canPostToChannel(request.resource.data.convId));
      // Anyone may react (toggleReaction only ever touches the `reactions`
      // map) — editing the message itself or deleting it is sender/admin
      // only. Previously anyone could edit/delete any other user's message.
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    // ── Team Space presence (heartbeat) ───────────────────────
    match /teamspacePresence/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId);
    }

    // ── Onboarding Training ────────────────────────────────────
    // Content (modules/steps) is readable by everyone taking a walkthrough
    // but only Admin/Super Admin can author/edit it.
    match /onboardingTrainingModules/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /onboardingTrainingSteps/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Progress is private to the employee it belongs to, plus Admin/HR for
    // compliance tracking (mirrors the certificates visibility below).
    match /onboardingTrainingProgress/{id} {
      allow read:   if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Certificates are immutable once issued — an employee can create their
    // own (on module completion) and read their own; Admin/HR can read
    // everyone's for compliance tracking, but nobody edits/deletes one.
    match /trainingCertificates/{id} {
      allow read:   if isAuthenticated() && (resource.data.employeeUserId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.employeeUserId == request.auth.uid;
    }

    // Practice ("try it") submissions from inside a training walkthrough —
    // demo data only, entirely separate from any real collection. Same
    // immutable-once-created, own-records-plus-admin visibility as
    // certificates.
    match /trainingPracticeSubmissions/{id} {
      allow read:   if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // ── Notifications ────────────────────────────────────────
    match /notifications/{id} {
      allow read: if isAuthenticated() &&
                     resource.data.recipientId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
                       resource.data.recipientId == request.auth.uid;
      allow delete: if isAuthenticated() &&
                       resource.data.recipientId == request.auth.uid;
    }

    // ── Settings ─────────────────────────────────────────────
    // Shared by company-settings, incentive-settings, leave-policy, and
    // permissions docs. Admin can write any of them, EXCEPT flipping
    // Maintenance Mode on the company doc — that toggle is hidden from
    // plain Admin in the UI (super_admin-only) and must actually be
    // enforced here too. The `incentives` doc is the one exception in the
    // other direction — IncentivesPage explicitly lets Sales Head set the
    // incentive structure too ("Only Admin/Sales Head set the incentive
    // structure"), so it needs its own allowance alongside Admin's.
    match /settings/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || (id == 'incentives' && getUserRole() == 'sales_head')
                       || (id == 'referralProgram' && getUserRole() == 'marketing');
      allow update: if (
        isAdmin() && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(
            ['maintenanceMode', 'maintenanceMessage']
          ) || isSuperAdmin()
        )
      ) || (id == 'incentives' && getUserRole() == 'sales_head')
        || (id == 'referralProgram' && getUserRole() == 'marketing');
      allow delete: if isAdmin();
    }

    // ── Referral program (Marketing) ─────────────────────────
    // Bonus records are created automatically as a side effect of
    // Operations confirming a booking (createReferralBonusIfEligible),
    // so any authenticated staff member can create one — but only
    // Admin/Marketing can mark one paid, since that's the team that owns
    // this program and actually settles the payout outside the system.
    match /referralBonuses/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields();
      allow update: if isAdmin() || getUserRole() == 'marketing';
      allow delete: if isAdmin();
    }

    // Freelance Referral Executives — holds bank account/UPI payout
    // details, so (like teamPulseResponses) this is excluded from the
    // generic catch-all below and given its own restricted read: only
    // Admin/Marketing (who manage the program and settle payouts) can see
    // it, not every authenticated employee. The public /r/{code} link and
    // its lookup route only ever go through the Admin SDK server-side
    // (bypassing these rules), so this restriction never blocks that flow.
    match /referralPartners/{id} {
      allow read: if isAdmin() || getUserRole() == 'marketing';
      allow create, update: if isAdmin() || getUserRole() == 'marketing';
      allow delete: if isAdmin();
    }

    // Poster artwork/captions — not sensitive, any authenticated staff
    // member can view the kit; only Admin/Marketing manage it.
    match /referralPosters/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || getUserRole() == 'marketing';
      allow delete: if isAdmin();
    }

    // Click analytics for the /r/{code} public link — written only by the
    // Admin SDK (that route bypasses these rules entirely), read restricted
    // to Admin/Marketing same as the other referral-program internals.
    match /referralClicks/{id} {
      allow read: if isAdmin() || getUserRole() == 'marketing';
      allow write: if false;
    }

    // ── Customer/Partner self-service portals ─────────────────────────
    // Portal sessions (Firebase custom tokens for synthetic "cust_{id}" /
    // "partner_{id}" uids, minted by /api/portal/login) never talk to
    // Firestore directly — every /api/portal/* route reads/writes via the
    // Admin SDK after verifying the caller's own token server-side
    // (requirePortalAuth), so these two collections only need normal
    // staff-facing rules; write:false blocks any client write of either
    // kind (staff or portal), matching every other "server writes only"
    // collection in this file.
    // No `allow create` here — every doc is written by the Admin SDK from
    // /api/portal/customer/booking-requests, which bypasses these rules
    // entirely, so create is implicitly denied for any client write.
    match /bookingRequests/{id} {
      allow read, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Same reasoning — written only by /api/portal/quick-inquiry.
    match /quickInquiries/{id} {
      allow read, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Help Center (AI assistant knowledge base) ────────────
    match /helpArticles/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── HR Policy Documents (grounds the Ask HR assistant) ────────────
    // extractedText is only ever written server-side by
    // /api/hrms/policies/extract (Admin SDK, bypasses this rule) — the
    // client only ever creates the initial record (fileUrl set,
    // extractedText null) and reads/archives/deletes afterward.
    match /hrPolicyDocuments/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || getUserRole() == 'hr';
    }

    // ── Reference number counters (internal) ─────────────────
    // One doc per prefix (e.g. "WGO", "INV"), storing the next sequence
    // number — written transactionally by nextRefNumber() whenever any
    // module creates a new record. Not user-facing data, so it doesn't go
    // through hasRequiredFields() like normal business records do.
    match /refCounters/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ── System usage (Admin "Usage & Quotas" panel) ───────────
    // Only ever written by the sync-supabase cron via the Admin SDK,
    // which bypasses these rules entirely — `write: if false` here just
    // means no CLIENT (of any role) can ever write to it directly.
    match /systemUsage/{id} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── AI usage log (Admin "AI Usage" reporting, Phase 1 of the AI/ML
    // roadmap) ─────────────────────────────────────────────────────
    // Every entry is written server-side by geminiService.ts via the Admin
    // SDK (ai-usage-log.service.ts), which bypasses these rules entirely —
    // same precedent as systemUsage above: `write: if false` just blocks
    // any client of any role from writing here directly.
    match /aiUsageLogs/{id} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── AI action logs (unified assistant write-tool audit trail) ──
    // Written only by the trusted Admin-SDK path in
    // ai-action-log.service.ts after the client executes an AI-proposed
    // write via the normal createLead/createQuotation service functions —
    // same admin-only-write boundary as aiUsageLogs above.
    match /aiActionLogs/{id} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── AI ML predictions (revenue forecast, lead conversion model) ──
    // Written only by /api/cron/weekly-ml-predictions via the Admin SDK,
    // after validating api/ml/forecast.py's (Python) response — same
    // admin-only-write boundary as aiUsageLogs/aiActionLogs above.
    match /aiPredictions/{id} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── Team Pulse (anonymous check-in, Phase 5 of the AI/ML roadmap) ──
    // "Anonymous to viewers, traceable in the database" — the app's own
    // Team Pulse UI never reads or displays individual documents (only the
    // aggregate, computed server-side by /api/team-pulse/results via the
    // Admin SDK), but each doc still carries a `createdBy` uid for abuse
    // prevention, so isAdmin() can still see who-said-what through the raw
    // Collection Explorer if truly needed. Doc ID is always
    // `${roundId}_${uid}` (enforced client-side, not by these rules) so a
    // resubmission overwrites rather than creating a second response.
    match /teamPulseResponses/{id} {
      // A user may read their OWN response doc directly by ID (that's all
      // hasSubmittedThisRound() does — "have I already answered this
      // round"), but can't query/list the collection, since a list query
      // requires every matched doc to satisfy the rule and only one ever
      // will. Aggregate stats come from /api/team-pulse/results (Admin
      // SDK) instead, never a client-side query.
      allow read: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      allow create, update: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Scheduled digests (Phase 2 of the AI/ML roadmap) ──────────────
    // Precomputed weekly/daily summaries (e.g. sales leaderboard) written
    // by Vercel Cron routes via the Admin SDK, same `write: if false`
    // precedent as systemUsage/aiUsageLogs above. Readable by any
    // authenticated user — these are team-facing (leaderboard, digests),
    // not sensitive like the AI usage/audit logs are.
    match /digests/{id} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // ── Activity log (cross-department audit trail) ──────────
    // Previously had no dedicated rule (fell through to the permissive
    // catch-all below, which additionally requires hasRequiredFields() on
    // create) — logActivity()'s write shape ({entityType, entityName,
    // action, detail, actorId, actorName, createdAt}) doesn't include
    // those fields, so every single write was being silently rejected.
    // Same non-standard-shape precedent as teamspaceMessages/notifications
    // above: skip hasRequiredFields() rather than force artificial fields
    // onto an audit record. Bulk/unfiltered reads (the admin-only Activity
    // Log page, EmployeeProfile's per-employee activity tab) stay
    // Admin/HR-only — this is an internal audit trail, not something every
    // employee should browse freely. The actorId branch is narrower: it
    // only ever satisfies a query pre-filtered by `where('actorId','==',uid)`
    // (fetchRecentActivityByActor) — Firestore can't prove an unfiltered
    // query safe against a per-document condition, so this exists
    // specifically to let ESS's "My Activity" tab read the signed-in
    // employee's own trail without the broader audit-log permission.
    match /activities/{id} {
      allow read:          if isAdmin() || getUserRole() == 'hr' || resource.data.actorId == request.auth.uid;
      allow create:        if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ── Trash (soft-delete recovery) ─────────────────────────
    // `create` stays open to any authenticated user because every delete()
    // across every collection writes a trash copy first, regardless of
    // which role was allowed to delete that original record — restricting
    // create here would break normal deletes for non-admin roles. Restoring
    // or permanently purging a trashed record is Admin/Super Admin only.
    match /trash/{id} {
      allow read:   if isAdmin();
      allow create: if isAuthenticated() && hasRequiredFields();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Holidays (company holiday calendar) ──────────────────
    match /holidays/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Assets (inventory + employee requests) ───────────────
    match /assets/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // Any employee can create/read their own request; approving/rejecting
    // (ESS inbox) is done by the employee's reporting manager or HR/Admin —
    // matches asset-request.service.ts's create/approve/reject call sites.
    match /assetRequests/{id} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields();
      allow update: if isAuthenticated() && (
        isOwnerOrManagerOfEmployee(resource.data.employeeId) ||
        getUserRole() in ['super_admin', 'admin', 'hr']
      ) && assetRequestOwnerWriteIsSafe(resource.data.employeeId);
      allow delete: if isAdmin();
    }

    // ── Performance (reviews/goals — sensitive HR data) ──────
    match /performanceReviews/{id} {
      allow read:  if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
      allow write: if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
    }

    match /performanceGoals/{id} {
      allow read:  if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
      allow write: if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
    }

    // ── Recruitment (candidate PII + job openings) ───────────
    match /candidates/{id} {
      allow read:  if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
      allow write: if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
    }

    match /jobOpenings/{id} {
      allow read:  if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
      allow write: if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'hr'];
    }

    // ── Company Goals ─────────────────────────────────────────
    // Visible company-wide for transparency; only Admin/Super Admin
    // (matches the Admin-panel-only surface that manages these) may write.
    match /companyGoals/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    match /objectives/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    match /goalCheckIns/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── WhatsApp message templates ────────────────────────────
    // Templates are created/approved manually in Meta's WhatsApp
    // Manager; this collection just records the approved template's
    // name/language/variables so business logic can look up "the
    // approved template for purpose X" generically. Not sensitive —
    // read stays open to any authenticated user; write restricted to
    // Admin/Super Admin (matches the Admin-panel-only surface that
    // manages these). The smart-send helper reads it server-side via
    // the Admin SDK, which bypasses these rules entirely.
    match /whatsappTemplates/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── NPS responses (Review & NPS engine) ────────────────────
    // Written exclusively by the public, no-login /review/{token} route
    // via the Admin SDK (bypasses this file entirely) — there's no
    // legitimate client write path, so writes are locked to Admin same as
    // whatsappTemplates above. Read stays open to any authenticated staff
    // member for the Reviews & NPS reputation dashboard.
    // reviewRequests has no dedicated rule — it's created client-side by
    // scheduleReviewRequest() when a booking completes, and the plain
    // catch-all's isAuthenticated() read/create/update grant below is
    // exactly the access it needs (same as most other modules).
    match /npsResponses/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Tally ledger mappings (accounting bridge) ──────────────
    // Admin-managed lookup table (ERP expense category / system account ->
    // Tally ledger name+group) — same reasoning as whatsappTemplates: read
    // open to any authenticated user (Finance needs it to see/export), write
    // restricted to Admin. tallyExports (the per-export log) has no
    // dedicated rule — it's written client-side by whichever authenticated
    // finance/admin user triggers an export, and the catch-all's plain
    // isAuthenticated() grant is exactly right, same as reviewRequests.
    match /tallyMappings/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Marketing automation (drip journeys) ───────────────────
    // journeys/segments are marketing-configured definitions — read open
    // to any authenticated user, write restricted to Admin, same reasoning
    // as whatsappTemplates/tallyMappings. journeyRuns has no dedicated
    // rule — created client-side by the quote_sent/trip_completed hook
    // points and advanced server-side by the journey-engine cron (Admin
    // SDK, bypasses this file), so the catch-all's plain isAuthenticated()
    // grant is exactly right, same as reviewRequests/tallyExports.
    match /journeys/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }
    match /segments/{id} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── WhatsApp conversations (per-employee inbox) ────────────
    // Same assignedTo/agentName pattern as leads/customers/bookings — an
    // unassigned conversation is visible/claimable by anyone; once
    // assigned, only the assignee, an admin, or a view-all role
    // (operations/sales_head by default) sees it. Reassignment is gated
    // the same way as customers/bookings (canReassign — admin/super_admin/
    // sales_head). create is left as permissive as the catch-all (matches
    // leads/customers/bookings precedent) since the webhook route creates
    // these via the Admin SDK anyway, bypassing this entirely.
    match /whatsappConversations/{id} {
      allow read: if isAuthenticated() && canViewAssigned('whatsapp:view_all');
      allow create: if isAuthenticated() && hasRequiredFields();
      // Unlike customers/bookings' equivalent rule, this also lets anyone
      // claim a currently-unassigned conversation (resource.data.assignedTo
      // == null) — touchesAssignmentFields() alone can't tell "null → me"
      // (claiming) apart from "someone → someone else" (reassigning), and
      // both need to be allowed for a non-privileged agent, only the
      // second blocked.
      allow update: if isAuthenticated() && (
        resource.data.get('assignedTo', null) == null ||
        !touchesAssignmentFields(['assignedTo', 'agentName']) ||
        canReassign()
      );
      allow delete: if isAdmin();
    }

    // Message bodies are the actual sensitive content — restricting the
    // conversation list alone would be pointless if any authenticated user
    // could still read every message directly. Visibility follows the
    // parent conversation's own assignedTo (canViewWhatsAppConversation).
    // create/update stay as permissive as the catch-all: outbound sends go
    // through /api/whatsapp/send and inbound through the webhook, both
    // Admin SDK (bypass this file entirely) — no legitimate client write
    // path exists today for either verb.
    match /whatsappMessages/{id} {
      allow read: if isAuthenticated() && canViewWhatsAppConversation(resource.data.conversationId);
      allow create: if isAuthenticated() && hasRequiredFields();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── All other collections ─────────────────────────────────
    // create/update validate the standard fields; delete has no
    // incoming request.resource to validate, so hasRequiredFields()
    // must never gate it (it errors on a null request.resource,
    // which silently denies every delete under this rule).
    // Delete requires Admin — this previously allowed ANY authenticated
    // user to delete documents in any collection with no dedicated rule
    // (e.g. the audit-log `activities` collection), which is exactly the
    // gap the Admin-only Collection Explorer screen relied on the UI (not
    // the rules) to prevent. Delete never needs a per-collection exclusion
    // like read/create/update do below: this isAdmin() grant is already the
    // strictest delete permission any dedicated rule above asks for, so
    // OR'ing it in can only ever match what a dedicated rule already allows
    // (or, for a few HR collections that intentionally let 'hr' delete too,
    // add to what's already explicitly granted there) — never more.
    //
    // See isReadRestricted/isCreateRestricted/isUpdateRestricted above for
    // why read/create/update all need an explicit per-collection exclusion
    // list instead: a stricter dedicated rule above can never actually
    // restrict what this catch-all grants on its own, only add to it.
    match /{collection}/{id} {
      allow read:   if isAuthenticated() && !isReadRestricted(collection);
      allow create: if isAuthenticated() && hasRequiredFields() && !isCreateRestricted(collection);
      allow update: if isAuthenticated() && hasRequiredFields() && !isUpdateRestricted(collection);
      allow delete: if isAdmin();
    }
  }
}
